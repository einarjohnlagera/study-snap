# Copy this file to create your local env files.
# - Frontend: create frontend/.env.local
# - Backend: set environment variables or use application-local.yml

#######################################
# Frontend (Next.js) - frontend/.env.local
#######################################

# Base URL of backend API (dev)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional: app environment name
NEXT_PUBLIC_APP_ENV=local

#######################################
# Backend (Spring Boot)
#######################################

# Server
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database (if/when you add persistence)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=studysnap
DB_USER=studysnap
DB_PASSWORD=changeme

# OCR Provider (choose one and wire later)
OCR_PROVIDER=google_vision
OCR_API_KEY=changeme

# LLM Provider
LLM_PROVIDER=openai
LLM_API_KEY=changeme

# Model tiers (example placeholders)
LLM_MODEL_FREE=gpt-4o-mini
LLM_MODEL_PREMIUM=gpt-5

# Optional: logging
LOG_LEVEL=INFO
