# Frontend: copy to frontend/.env.local
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_APP_ENV=local

# Backend env vars (or application-local.yml)
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional DB
DB_HOST=localhost
DB_PORT=5432
DB_NAME=studysnap
DB_USER=studysnap
DB_PASSWORD=changeme

# OCR/LLM providers (wire later)
OCR_PROVIDER=google_vision
OCR_API_KEY=changeme
LLM_PROVIDER=openai
LLM_API_KEY=changeme
LOG_LEVEL=INFO
